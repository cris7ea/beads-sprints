{
  "name": "beads-sprints",
  "version": "0.1.6",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "start": "vite build && electron .",
    "make-mac-app": "vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir",
    "release": "node scripts/release.mjs"
  },
  "build": {
    "appId": "com.beads-sprints.app",
    "directories": {
      "output": "release"
    },
    "productName": "Beads Sprints",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
